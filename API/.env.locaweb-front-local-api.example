# Exemplo para deixar o FRONT na Locaweb e a API/Banco rodando localmente.
# Copie para .env e ajuste os placeholders.

NODE_ENV=development
PORT=3001

# Banco local
DATABASE_URL="postgresql://usuario:senha@localhost:5432/curriculos?schema=public"

# Inclua aqui o dominio publicado na Locaweb e os enderecos locais usados em teste.
# Exemplo:
# CORS_ORIGIN="https://seudominio.com.br,http://localhost:5173,http://192.168.71.130:5173"
CORS_ORIGIN="https://SEU-DOMINIO-LOCAWEB.com.br,http://localhost:5173,http://192.168.71.130:5173"

# Usado nos links de recuperacao de senha enviados por email.
FRONTEND_URL="https://SEU-DOMINIO-LOCAWEB.com.br"

JWT_SECRET="troque-por-uma-chave-grande-e-aleatoria"
JWT_EXPIRES_IN="1d"
ADMIN_CREATE_SECRET="troque-por-outra-chave-grande"
PASSWORD_RESET_SECRET="troque-por-uma-chave-grande-e-aleatoria"
PASSWORD_RESET_EXPIRES_IN="1h"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"
MAIL_FROM="Metalurgica Vulcano <no-reply@vulcano.com>"
